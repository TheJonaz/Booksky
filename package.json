{
  "name": "booksky",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "db:push": "npm run push -w @booksky/db",
    "db:seed": "npm run seed -w @booksky/db",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test": "npm run test --workspace=@booksky/core"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
